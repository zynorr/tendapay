{
  "name": "tendapay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:domain && npm run test:server",
    "test:domain": "node --test --experimental-strip-types tests/invoice.test.mjs",
    "test:server": "tsx --test tests/server/postgres-invoice-repository.test.ts tests/server/deliverable-storage.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@celo/attribution-tags": "^0.3.0",
    "lucide-react": "^0.475.0",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "thirdweb": "5.120.1",
    "viem": "2.55.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.10",
    "pg-mem": "^3.0.14",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0"
  }
}

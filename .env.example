# Optional. Required only when live Celo payments are enabled.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Assigned during Celo Builders registration. Development falls back to a
# deterministic hostname-derived tag when this is left blank.
NEXT_PUBLIC_CELO_ATTRIBUTION_CODE=

# Optional production persistence. Without these values TendaPay uses local
# JSON and disk storage under .data.
DATABASE_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Required in production. Use at least 32 random bytes, encoded as hex or
# base64. Development generates an in-memory secret when this is left blank.
AUTH_SECRET=

# Required for the server-side x402 milestone endpoint.
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
X402_FACILITATOR_URL=https://x402.celo.org
